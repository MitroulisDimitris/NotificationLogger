<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="7dp"
    android:paddingBottom="7dp"
    android:background="@drawable/ripple_dark"
    android:minHeight="40dp">

    <!-- TIME: fixed width -->
    <TextView
        android:id="@+id/colTime"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:textColor="#556677"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:lineSpacingMultiplier="1.1"/>

    <!-- APP: fixed width, truncated -->
    <TextView
        android:id="@+id/colApp"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:textColor="#00D4FF"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end"/>

    <!-- SENDER: flex -->
    <TextView
        android:id="@+id/colSender"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#CCDDEE"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:paddingEnd="4dp"/>

    <!-- MESSAGE: flex x2 -->
    <TextView
        android:id="@+id/colMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:textColor="#8899AA"
        android:textSize="11sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:paddingEnd="4dp"/>

    <!-- TYPE: badge pill, fixed width -->
    <TextView
        android:id="@+id/colType"
        android:layout_width="68dp"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="8sp"
        android:gravity="center"
        android:padding="3dp"
        android:background="@drawable/rounded_pill"
        android:maxLines="2"
        android:lineSpacingMultiplier="1.1"/>

</LinearLayout>
