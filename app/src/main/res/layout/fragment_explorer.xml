<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1B2A">

    <!-- ── Header bar ─────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="8dp"
        android:paddingTop="10dp"
        android:paddingBottom="8dp"
        android:background="#0A1520">

        <TextView
            android:text="🔍 Explorer"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>

        <Spinner
            android:id="@+id/spinnerExplorerDays"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:backgroundTint="#00D4FF"/>
    </LinearLayout>

    <!-- ── Filter panel ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111E2E"
        android:paddingBottom="6dp">

        <!-- Row 1: full-text search -->
        <SearchView
            android:id="@+id/searchExplorer"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:iconifiedByDefault="false"
            android:queryHint="Search text / title..."
            android:background="#0D1B2A"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="6dp"/>

        <!-- Row 2: sender filter -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:text="From: "
                android:textColor="#778899"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etSenderFilter"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:hint="Sender name…"
                android:textColor="#FFFFFF"
                android:textColorHint="#445566"
                android:textSize="13sp"
                android:background="#0D1B2A"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="text"
                android:imeOptions="actionDone"/>

            <Button
                android:id="@+id/btnSenderApply"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Go"
                android:textSize="12sp"
                android:backgroundTint="#00D4FF"
                android:textColor="#000000"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <!-- Row 3: App + Type spinners -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp">

            <Spinner
                android:id="@+id/spinnerAppFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#334455"
                android:layout_marginEnd="4dp"/>

            <Spinner
                android:id="@+id/spinnerTypeFilter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="#334455"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Row 4: result count + clear -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="4dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvExplorerCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#00D4FF"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="Loading…"/>

            <TextView
                android:id="@+id/btnClearFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕ Clear"
                android:textColor="#FF6680"
                android:textSize="12sp"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ── Column headers (sticky) ────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:background="#0A1520"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:gravity="center_vertical">

        <TextView android:text="TIME" android:layout_width="72dp" android:layout_height="wrap_content"
            android:textColor="#00D4FF" android:textSize="10sp" android:fontFamily="monospace"/>
        <TextView android:text="APP" android:layout_width="70dp" android:layout_height="wrap_content"
            android:textColor="#00D4FF" android:textSize="10sp" android:fontFamily="monospace"/>
        <TextView android:text="FROM" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#00D4FF" android:textSize="10sp" android:fontFamily="monospace"/>
        <TextView android:text="MESSAGE" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="2" android:textColor="#00D4FF" android:textSize="10sp" android:fontFamily="monospace"/>
        <TextView android:text="TYPE" android:layout_width="68dp" android:layout_height="wrap_content"
            android:textColor="#00D4FF" android:textSize="10sp" android:fontFamily="monospace" android:gravity="end"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1A3040"/>

    <!-- ── Data rows ───────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvExplorer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp"/>

</LinearLayout>
